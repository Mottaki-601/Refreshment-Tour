@{
    ViewData["Title"] = "Home Page";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #6e8efb, #a777e3);
        color: white;
        padding: 100px 0;
        border-radius: 20px;
        margin-bottom: 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .feature-card {
        transition: transform 0.3s, box-shadow 0.3s;
        border: none;
        border-radius: 15px;
    }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

    .icon-box {
        font-size: 3rem;
        margin-bottom: 15px;
        color: #6e8efb;
    }

    .lead {
        animation: fadeUp 6s ease-out forwards;
        opacity: 0;
    }

    @@keyframes fadeUp {
        0% {
            opacity: 0;
            transform: translateY(20px) skewX(-10deg);
        }

        100% {
            opacity: 1;
            transform: translateY(0) skewX(0deg);
        }
    }
</style>

<div class="container">
    <div class="hero-section text-center">
        <marquee behavior="scroll" direction="left" class="display-3 fw-bold">
            স্বাগতম আমাদের ট্যুর ম্যানেজমেন্টে
        </marquee>
        <p class="lead mb-4 cursive-animation">
            আপনার ভ্রমণকে আরও সহজ এবং স্মরণীয় করে তুলতে আমরা আছি আপনার সাথে।
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Members" asp-action="Index" class="btn btn-light btn-lg px-4 fw-bold text-primary">মেম্বার লিস্ট</a>
            <a asp-controller="Gallery" asp-action="Index" class="btn btn-outline-light btn-lg px-4">গ্যালারি দেখুন</a>
        </div>
    </div>

    <div class="row text-center mt-5">
        <div class="col-md-4 mb-4">
            <div class="card feature-card h-100 p-4">
                <div class="icon-box"><i class="fa fa-users"></i></div>
                <h3>মেম্বার ম্যানেজমেন্ট</h3>
                <p class="text-muted">খুব সহজেই মেম্বার যোগ করুন এবং তাদের পেমেন্ট ট্র্যাক করুন।</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card feature-card h-100 p-4">
                <div class="icon-box"><i class="fa fa-calculator"></i></div>
                <h3>অটো ক্যালকুলেশন</h3>
                <p class="text-muted">খরচ এবং বাকি টাকার হিসাব রাখুন নিমিষেই রিয়েল-টাইম পদ্ধতিতে।</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card feature-card h-100 p-4">
                <div class="icon-box"><i class="fa fa-camera-retro"></i></div>
                <h3>ফটো গ্যালারি</h3>
                <p class="text-muted">ভ্রমণের সুন্দর মুহূর্তগুলো ছবির মাধ্যমে সাজিয়ে রাখুন আমাদের গ্যালারিতে।</p>
            </div>
        </div>
    </div>
</div>
