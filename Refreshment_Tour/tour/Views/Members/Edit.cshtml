@model MemberVM
@{
    ViewData["Title"] = "Edit";
}

<div class="row">
    <form asp-action="Edit" asp-controller="Members" enctype="multipart/form-data" method="post">
        <div class="d-flex justify-content-between">
            <div class="col-6">
                <h2>Add new Member</h2>
                @Html.HiddenFor(x => x.MemberId)
                @Html.HiddenFor(x=>x.Image)
                @Html.HiddenFor(x => x.EventId)
                <div class="row mb-2">
                    <label asp-for="Name" class="col-form-label col-form-label-sm col-3"></label>
                    <div class="col-7">
                        <input asp-for="Name" class="form-control form-control-sm" />
                    </div>
                    <div class="col-2">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-2">
                    <label asp-for="RollNo" class="col-form-label col-form-label-sm col-3"></label>
                    <div class="col-7">
                        <input asp-for="RollNo" class="form-control form-control-sm" />
                    </div>
                    <div class="col-2">
                        <span asp-validation-for="RollNo" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-2">
                    <label asp-for="Amount" class="col-form-label col-form-label-sm col-3"></label>
                    <div class="col-7">
                        <input asp-for="Amount" class="form-control form-control-sm" />
                    </div>
                    <div class="col-2">
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-2">
                    <label asp-for="CourseId" class="col-form-label col-3"></label>
                    <div class="col-7">
                        <select asp-for="CourseId" class="form-select form-select-sm" asp-items="@(new SelectList(ViewBag.courses, "CourseId", "CourseName"))">
                            <option value="">--------Select-------</option>
                        </select>
                    </div>
                    <div class="col-2">
                        <span asp-validation-for="CourseId" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-2">
                    <label asp-for="ImageFile" class="col-3 col-form-label col-form-label-sm"></label>
                    <div class="col-7">
                        <input asp-for="ImageFile" class="form-control form-control-sm" type="file" />
                    </div>
                    <div class="col-2">
                        <span asp-validation-for="ImageFile" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <label asp-for="PaymentDone" class="col-3 col-form-label col-form-label-sm">
                        Payment Status
                    </label>
                    <div class="col-7 d-flex align-items-center">
                        <input asp-for="PaymentDone" class="form-check-input me-2" />
                        <span class="fw-bold text-success">Payment Completed</span>
                    </div>
                </div>

            </div>
        </div>
        <div class="row d-flex justify-content-end">
            <div class="col">
                <input type="submit" value="update Data" class="btn btn-success";/>
            </div>
        </div>
    </form>
</div>

