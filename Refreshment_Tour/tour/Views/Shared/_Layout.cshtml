<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Refreshment Tour</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/lib/font-awesome/css/font-awesome.css" rel="stylesheet" />

    <link rel="manifest" href="~/manifest.json">

    <style>
        :root {
            --nav-bg: linear-gradient(135deg, #1a2a6c 0%, #b21f1f 50%, #fdbb2d 100%); 
            --glass-nav: linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%);
            --accent-gold: #ffde59;
            --text-light: #f8f9fa;
        }

        body {
            background-color: #f1f3f6;
            font-family: 'Poppins', sans-serif;
            margin: 0;
            padding: 0;
        }

        .navbar {
            background: var(--glass-nav) !important;
            padding: 12px 0;
            box-shadow: 0 4px 25px rgba(0, 0, 0, 0.3);
            border-bottom: 2px solid var(--accent-gold);
            position:fixed;
            top:0;
            width:100%;
            z-index:999;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.6rem;
            color: var(--text-light) !important;
            letter-spacing: 1px;
        }

            .navbar-brand img {
                border: 2px solid var(--accent-gold);
                padding: 2px;
                background: white;
            }

            .navbar-brand span.text-danger {
                color: var(--accent-gold) !important; 
                text-transform: uppercase;
            }

        .nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
            font-weight: 500;
            margin: 0 8px;
            padding: 8px 15px !important;
            border-radius: 50px;
            transition: all 0.4s ease;
            position: relative;
        }

            .nav-link i {
                margin-right: 5px;
                color: var(--accent-gold);
            }

            .nav-link:hover {
                color: #fff !important;
                background: rgba(255, 255, 255, 0.1);
                transform: scale(1.05);
            }

            .nav-link::after {
                content: '';
                position: absolute;
                width: 0;
                height: 2px;
                bottom: 5px;
                left: 50%;
                background: var(--accent-gold);
                transition: all 0.3s ease;
            }

            .nav-link:hover::after {
                width: 50%;
                left: 25%;
            }

        .navbar-toggler {
            border: 1px solid var(--accent-gold);
            color: var(--accent-gold);
        }

        .main-content {
            min-height: calc(100vh - 200px);
            padding-top: 100px;
        }

        footer {
            background: #0f2027; 
            color: #bdc3c7;
            padding: 50px 0 20px 0;
            border-top: 3px solid var(--accent-gold);
        }

            footer h5 {
                color: var(--accent-gold);
                font-weight: 700;
                margin-bottom: 20px;
            }

            footer a {
                color: #ecf0f1;
                text-decoration: none;
                transition: 0.3s;
            }

                footer a:hover {
                    color: var(--accent-gold);
                    padding-left: 5px;
                }

        .social-icons a {
            background: rgba(255, 255, 255, 0.05);
            width: 45px;
            height: 45px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            margin: 0 5px;
            border: 1px solid rgba(255, 215, 0, 0.3);
        }

            .social-icons a:hover {
                background: var(--accent-gold);
                color: #000 !important;
                transform: rotate(360deg);
            }

        .footer-bottom {
            background: rgba(0,0,0,0.3);
            padding: 20px 0;
            margin-top: 40px;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/tour logo.jpeg" style="width:45px; height:45px; border-radius:10px;" class="me-2 shadow-sm" />
                    <span>Refreshment<span class="text-danger">Tour</span></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <i class="fa fa-bars"></i>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="fa fa-home"></i> Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Events" asp-action="Index"><i class="fa fa-connectdevelop"></i> Events</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Courses" asp-action="Index"><i class="fa fa-graduation-cap"></i> Course</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Members" asp-action="Index"><i class="fa fa-user-circle"></i> Members</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Gallery" asp-action="Index"><i class="fa fa-image"></i> Gallery</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-content">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4 text-center text-md-start">
                    <h5><i class="fa fa-paper-plane me-2"></i>About Tour</h5>
                    <p class="small">ভ্রমণ হোক আনন্দদায়ক এবং স্মৃতিময়। আমরা আপনার প্রতিটি ট্যুরকে সহজ ও গোছানো করতে কাজ করে যাচ্ছি। আমাদের সাথে যুক্ত থাকুন।</p>
                </div>
                <div class="col-md-4 mb-4 text-center">
                    <h5><i class="fa fa-link me-2"></i>Quick Navigation</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Gallery" asp-action="Index">Memories Gallery</a></li>
                        <li><a asp-controller="Members" asp-action="Index">Our Team</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Terms & Privacy</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-4 text-center text-md-end">
                    <h5><i class="fa fa-share-alt me-2"></i>Connect With Us</h5>
                    <div class="social-icons justify-content-center justify-content-md-end d-flex mt-3">
                        <a href="#" title="Facebook"><i class="fa fa-facebook-f"></i></a>
                        <a href="https://www.linkedin.com/in/mottaki-billah" target="_blank" title="LinkedIn"><i class="fa fa-linkedin"></i></a>
                        <a href="#" title="YouTube"><i class="fa fa-youtube-play"></i></a>
                        <a href="mailto:mottakibillah601@gmail.com" title="Contact"><i class="fa fa-envelope"></i></a>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom text-center">
            <div class="container">
                <p class="mb-0">&copy; 2026 - <span class="text-white fw-bold">Refreshment Tour</span>. All Rights Reserved. | <i class="fa fa-code text-warning"></i> Developed with Mottaki Billah ❤️</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function() {
                navigator.serviceWorker.register('/sw.js').then(function(registration) {
                    console.log('ServiceWorker registration successful');
                }, function(err) {
                    console.log('ServiceWorker registration failed: ', err);
                });
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>