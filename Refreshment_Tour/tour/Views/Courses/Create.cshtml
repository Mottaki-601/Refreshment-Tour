@model tour.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">

    <div class="glass-card p-5 shadow-lg">

        <h2 class="text-center fw-bold mb-4"
        <span style="font-size:1.8rem;">📚</span>
        <span style="background: linear-gradient(90deg,#6a11cb,#2575fc,#ff6a00);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;">
            Create New Course</span>
        </h2>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4 position-relative">
                <input asp-for="CourseName" class="form-control modern-input" placeholder=" " />
                <label asp-for="CourseName" class="floating-label">Course Name</label>
                <span asp-validation-for="CourseName" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-create w-100 mb-3">
                 Create Course
            </button>

            <a asp-action="Index" class="btn btn-back w-100">
                ← Back to List
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>

    .glass-card {
        width: 420px;
        border-radius: 22px;
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.3);
    }

    .modern-input {
        border-radius: 12px;
        padding: 14px;
        border: 1px solid #ddd;
        transition: 0.3s;
    }

        .modern-input:focus {
            border-color: #6a11cb;
            box-shadow: 0 0 10px rgba(106,17,203,0.2);
        }

    .floating-label {
        position: absolute;
        top: 12px;
        left: 15px;
        color: #999;
        transition: 0.2s;
        pointer-events: none;
        background: white;
        padding: 0 5px;
    }

    .modern-input:focus + .floating-label,
    .modern-input:not(:placeholder-shown) + .floating-label {
        top: -10px;
        font-size: 12px;
        color: #6a11cb;
    }

    .btn-create {
        background: linear-gradient(135deg,#ff6a00,#ee0979,#2575fc);
        background-size: 200% 200%;
        animation: move 4s ease infinite;
        color: white;
        border-radius: 50px;
        border: none;
        padding: 12px;
    }

    .btn-back {
        background: #f1f1f1;
        border-radius: 50px;
    }

    @@keyframes move {
        0% {
            background-position: 0% 50%
        }

        50% {
            background-position: 100% 50%
        }

        100% {
            background-position: 0% 50%
        }
    }
</style>