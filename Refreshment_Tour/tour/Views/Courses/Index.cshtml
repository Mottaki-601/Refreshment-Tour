@model IEnumerable<tour.Models.Course>

@{
    ViewData["Title"] = "Course List";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold mb-1">

                <span style="font-size:1.8rem;">📚</span>

                <span style="
        background: linear-gradient(90deg,#6a11cb,#2575fc,#ff6a00);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;">
                    Course Dashboard
                </span>

            </h3>
            <small class="text-muted">Manage all courses in one place</small>
        </div>

        <a asp-action="Create"
           class="btn px-4 py-2 text-white rounded-pill shadow add-btn">
            <i class="fa fa-plus me-1"></i> Add Course
        </a>

    </div>

    <!-- CARD WRAPPER -->
    <div class="glass-table p-3">

        <table class="table align-middle mb-0">

            <thead>
                <tr>
                    <th>Course Name</th>
                    <th class="text-center">Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr class="table-row">

                        <td>
                            <div class="fw-bold">
                                🎓 @item.CourseName
                            </div>
                        </td>

                        <td class="text-center">
                            <span class="badge status-badge">
                                Active
                            </span>
                        </td>

                        <td class="text-end">

                            <div class="action-group">

                                <a asp-action="Edit" asp-route-id="@item.CourseId"
                                   class="btn btn-sm btn-outline-primary rounded-circle"
                                   title="Edit">
                                    <i class="fa fa-pencil"></i>
                                </a>

                                <a asp-action="Details" asp-route-id="@item.CourseId"
                                   class="btn btn-sm btn-outline-info rounded-circle"
                                   title="Details">
                                    <i class="fa fa-eye"></i>
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.CourseId"
                                   class="btn btn-sm btn-outline-danger rounded-circle"
                                   onclick="return confirm('Are you sure?')"
                                   title="Delete">
                                    <i class="fa fa-trash"></i>
                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

<!-- STYLE -->
<style>

    /* ADD BUTTON */
    .add-btn {
        background: linear-gradient(135deg,#ff6a00,#ee0979,#2575fc);
        background-size: 200% 200%;
        animation: move 4s ease infinite;
    }

    /* GLASS TABLE */
    .glass-table {
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    /* TABLE HEADER */
    thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        color: #6b7280;
    }

    /* ROW EFFECT */
    .table-row {
        transition: 0.3s;
    }

        .table-row:hover {
            background: rgba(106,17,203,0.05);
            transform: scale(1.01);
        }

    /* STATUS BADGE */
    .status-badge {
        background: linear-gradient(135deg,#00c9ff,#92fe9d);
        color: #000;
        padding: 6px 14px;
        border-radius: 50px;
    }

    /* ACTION BUTTONS */
    .action-group a {
        margin-left: 5px;
        transition: 0.3s;
    }

        .action-group a:hover {
            transform: scale(1.15);
        }

    /* ANIMATION */
    @@keyframes move {
        0%

    {
        background-position: 0% 50%
    }

    50% {
        background-position: 100% 50%
    }

    100% {
        background-position: 0% 50%
    }

    }
</style>