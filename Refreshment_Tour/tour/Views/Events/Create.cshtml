@model tour.Models.Event

<div class="d-flex justify-content-center align-items-center" style="min-height:80vh;">

    <div class="glass-form p-5 shadow-lg">

        <h2 class="text-center fw-bold mb-4"
            style="background: linear-gradient(90deg,#6a11cb,#2575fc,#ff6a00);
                   -webkit-background-clip: text;
                   -webkit-text-fill-color: transparent;">
            ✨ Create New Event
        </h2>

        <form asp-action="Create" method="post">

            <div class="mb-4 position-relative">
                <input asp-for="EventName" class="form-control modern-input" placeholder=" " />
                <label asp-for="EventName" class="floating-label">Event Name</label>
                <span asp-validation-for="EventName" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 justify-content-between mt-4">

                <button type="submit" class="btn btn-create px-4">
                    🚀 Create Event
                </button>

                <a asp-action="Index" class="btn btn-cancel px-4">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>

    .glass-form {
        width: 420px;
        border-radius: 22px;
        background: rgba(255,255,255,0.6);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.3);
    }

    .modern-input {
        border-radius: 12px;
        padding: 14px;
        border: 1px solid #ddd;
        transition: 0.3s;
    }

        .modern-input:focus {
            border-color: #6a11cb;
            box-shadow: 0 0 10px rgba(106,17,203,0.2);
        }

    .floating-label {
        position: absolute;
        top: 12px;
        left: 15px;
        color: #999;
        transition: 0.2s;
        pointer-events: none;
        background: white;
        padding: 0 5px;
    }

    .modern-input:focus + .floating-label,
    .modern-input:not(:placeholder-shown) + .floating-label {
        top: -10px;
        font-size: 12px;
        color: #6a11cb;
    }

    .btn-create {
        background: linear-gradient(135deg,#ff6a00,#ee0979,#2575fc);
        color: white;
        border-radius: 50px;
        border: none;
        transition: 0.3s;
    }

        .btn-create:hover {
            transform: scale(1.05);
        }

    .btn-cancel {
        background: #f1f1f1;
        border-radius: 50px;
    }

</style>